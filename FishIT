local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

local BillboardStart = Remotes:WaitForChild("BillboardStart")
local BillboardUpdate = Remotes:WaitForChild("BillboardUpdate")
local SubmitWord = Remotes:WaitForChild("SubmitWord")
local BillboardEnd = Remotes:WaitForChild("BillboardEnd")

-- ==========================================
-- 1. FETCH DATABASE DARI WEB
-- ==========================================
local kamusKBBI = {}
local kataTerpakai = {}
local autoAktif = false

local urlKBBI = "https://raw.githubusercontent.com/Bhinneka/indonesian-wordlist/master/indonesian-words.txt"

print("Sedang mengunduh database KBBI...")
local success, rawData = pcall(function()
    return game:HttpGet(urlKBBI)
end)

if success and rawData then
    for kata in string.gmatch(rawData, "[^\r\n]+") do
        kata = string.lower(kata)
        if #kata > 1 then
            local hurufAwal = string.sub(kata, 1, 1)
            if not kamusKBBI[hurufAwal] then kamusKBBI[hurufAwal] = {} end
            table.insert(kamusKBBI[hurufAwal], kata)
        end
    end
    print("Database KBBI berhasil dimuat!")
else
    warn("Gagal mengunduh database KBBI.")
end

-- ==========================================
-- 2. LOGIKA AUTO SAMBUNG KATA
-- ==========================================
local function cariKata(hurufAwal)
    hurufAwal = string.lower(hurufAwal) 
    local listKata = kamusKBBI[hurufAwal]
    
    if listKata then
        for _, kata in ipairs(listKata) do
            if not kataTerpakai[kata] then
                kataTerpakai[kata] = true
                return kata
            end
        end
    end
    return nil
end

local function autoKetikKata(kata)
    local teksBerjalan = ""
    for i = 1, #kata do
        teksBerjalan = string.sub(kata, 1, i)
        
        local args = {teksBerjalan}
        if i == 1 then
            BillboardStart:FireServer(unpack(args))
        else
            BillboardUpdate:FireServer(unpack(args))
        end
        task.wait(0.05) -- Jeda aman anti-kick / anti-spam
    end
    
    SubmitWord:FireServer(teksBerjalan)
    task.wait(0.05)
    BillboardEnd:FireServer()
end

