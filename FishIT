-- ==========================================
-- 4. TRIGGER LEWAT REMOTEEVENT
-- ==========================================
-- UBAH NAMA "NamaRemoteGiliran" DENGAN NAMA REMOTE ASLI DARI GAME
local TurnRemote = Remotes:WaitForChild("NamaRemoteGiliran")

-- OnClientEvent digunakan untuk "mendengarkan" perintah dari server ke client
TurnRemote.OnClientEvent:Connect(function(arg1)
    if not autoAktif then return end
    
    -- Asumsi: Server mengirim huruf pertama sebagai argument pertama (arg1)
    -- Jika argumentnya berupa tabel atau urutannya berbeda, kamu harus menyesuaikannya.
    local hurufBaru = tostring(arg1)
    
    -- Mengambil karakter pertamanya saja untuk keamanan data
    hurufBaru = string.sub(hurufBaru, 1, 1)
    
    if hurufBaru ~= "" then
        Status.Text = "Giliran! Huruf: " .. hurufBaru
        print("[Auto KBBI] Menerima huruf: " .. hurufBaru)
        
        local kataPilihan = cariKata(hurufBaru)
        
        if kataPilihan then
            Status.Text = "Mengetik: " .. kataPilihan
            autoKetikKata(kataPilihan)
            Status.Text = "Selesai ketik."
        else
            Status.Text = "Kata habis!"
            warn("[Auto KBBI] Kamus habis untuk huruf: " .. hurufBaru)
        end
    end
end)
