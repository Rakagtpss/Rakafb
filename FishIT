-- Variabel status Auto-Detect
local isAutoON = false
local isTyping = false -- Mencegah script spam ngetik dobel

-- ==========================================
-- 2. MENGUNDUH DATABASE KBBI
-- ==========================================
local urlKBBI = "https://raw.githubusercontent.com/damzaky/kumpulan-kata-bahasa-indonesia-KBBI/master/legacy/indonesian-words.txt"
local success, response = pcall(function() return game:HttpGet(urlKBBI) end)

local daftarKataKBBI = {}
if success then
	local cleanData = string.gsub(response, "\r", "")
	daftarKataKBBI = string.split(cleanData, "\n")
	StatusTxt.Text = "Siap! " .. #daftarKataKBBI .. " kata dimuat."
else
	StatusTxt.Text = "❌ Gagal mengunduh kata!"
end

-- ==========================================
-- 3. LOGIC PENCARIAN & AUTO-KETIK
-- ==========================================
local function cariKataYangCocok(sukuKata)
	sukuKata = string.lower(sukuKata)
	local kataCocok = {}
	
	for _, kata in ipairs(daftarKataKBBI) do
		if string.find(string.lower(kata), sukuKata) then
			table.insert(kataCocok, kata)
		end
	end
	
	if #kataCocok > 0 then
		return kataCocok[math.random(1, #kataCocok)]
	else
		return nil
	end
end

local function autoKetik(kata, delayNgetik)
	isTyping = true
	StatusTxt.Text = "Mengetik: " .. kata
	local currentText = ""
	
	for i = 1, #kata do
		local huruf = string.sub(kata, i, i)
		currentText = currentText .. huruf
		
		if i == 1 then
			Remotes:WaitForChild("BillboardStart"):FireServer(currentText)
		else
			Remotes:WaitForChild("BillboardUpdate"):FireServer(currentText)
		end
		
		task.wait(delayNgetik)
	end
	
	Remotes:WaitForChild("SubmitWord"):FireServer(string.lower(kata))
	Remotes:WaitForChild("BillboardEnd"):FireServer()
	
	task.wait(0.5)
	StatusTxt.Text = "Standby..."
	isTyping = false
end

-- ==========================================
-- 4. SISTEM FULL AUTO-DETEKSI DARI MATCH UI
-- ==========================================
math.randomseed(os.time())

-- PERHATIAN: Kamu mungkin perlu menambahkan spesifik lokasi TextLabel-nya di bawah ini!
-- Jika error, cek di Dark Dex apakah ada frame lagi setelah "MatchUI"
local MatchUI = LocalPlayer.PlayerGui:WaitForChild("MatchUI")

-- Asumsi lokasi Teks adalah TextLabel di dalam MatchUI (UBAH JIKA PERLU)
-- Misalnya: local TeksGiliran = MatchUI.Frame.TeksSukuKata
local TeksGiliran = MatchUI -- << GANTI INI KE PATH TEXTLABEL YANG BENAR JIKA TIDAK JALAN

-- Event Listener: Memantau perubahan teks di layar gamenya
if TeksGiliran:IsA("TextLabel") or TeksGiliran:IsA("TextBox") then
	TeksGiliran:GetPropertyChangedSignal("Text"):Connect(function()
		local sukuKataMuncul = TeksGiliran.Text
		
		-- Syarat jalan: Auto harus ON, Tidak sedang ngetik, Teks tidak boleh kosong
		if isAutoON and not isTyping and sukuKataMuncul ~= "" and #sukuKataMuncul >= 2 then
			local delayNgetik = tonumber(InputDelay.Text) or 0.1 
			local kataDitemukan = cariKataYangCocok(sukuKataMuncul)
			
			if kataDitemukan then
				task.spawn(function()
					autoKetik(kataDitemukan, delayNgetik)
				end)
			else
				StatusTxt.Text = "❌ Kata tdk ada di KBBI!"
			end
		end
	end)
else
	warn("TeksGiliran belum menunjuk ke TextLabel yang benar! Cek baris 108 di script.")
	StatusTxt.Text = "⚠️ Path TextLabel salah!"
end

-- Logic Tombol Sakelar UI
ToggleBtn.MouseButton1Click:Connect(function()
	isAutoON = not isAutoON
	
	if isAutoON then
		ToggleBtn.Text = "AUTO DETECT: ON"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Hijau
		StatusTxt.Text = "Sistem Aktif. Menunggu huruf..."
	else
		ToggleBtn.Text = "AUTO DETECT: OFF"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Merah
		StatusTxt.Text = "Sistem Dimatikan."
	end
end)
