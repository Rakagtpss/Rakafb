-- ==========================================
-- 4. KONTROL TOMBOL & AUTO BOT
-- ==========================================
local isAutoBotOn = false

-- Load Kamus di awal
task.spawn(function()
    if loadKamus() then
        StatusText.Text = "✅ Siap digunakan!"
    else
        StatusText.Text = "❌ Gagal muat kamus!"
        StatusText.TextColor3 = Color3.fromRGB(255, 50, 50)
    end
end)

-- Tombol Jawab Manual (Tapi deteksi otomatis)
BtnJawab.MouseButton1Click:Connect(function()
    StatusText.Text = "Mendeteksi & Mengetik..."
    local hasil = eksekusiAutoJawab()
    StatusText.Text = hasil
end)

-- Tombol Toggle Auto Bot
BtnAuto.MouseButton1Click:Connect(function()
    isAutoBotOn = not isAutoBotOn
    if isAutoBotOn then
        BtnAuto.Text = "Auto Bot: ON"
        BtnAuto.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        StatusText.Text = "Bot aktif! Menunggu giliran..."
        
        -- Jika PathTeks_Target diisi, pantau setiap kali teksnya berubah
        if PathTeks_Target then
            PathTeks_Target:GetPropertyChangedSignal("Text"):Connect(function()
                if isAutoBotOn and PathTeks_Target.Text ~= "" then
                    task.wait(0.5) -- Jeda setengah detik agar tidak kelihatan seperti citer
                    StatusText.Text = eksekusiAutoJawab()
                end
            end)
        end
    else
        BtnAuto.Text = "Auto Bot: OFF"
        BtnAuto.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        StatusText.Text = "Bot dimatikan."
    end
end)
