-- ==========================================
-- SCRIPT SAMBUNG KATA FULL AUTO BOT + UI
-- ==========================================

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

-- ==========================================
-- ⚙️ KONFIGURASI UTAMA (WAJIB DIISI) ⚙️
-- ==========================================
-- Ganti bagian 'nil' di bawah ini dengan Path hasil copy dari Dex Explorer!
-- Contoh: local PathTeks_Target = player.PlayerGui.MainGui.WordFrame.TextLabel
local PathTeks_Target = nil 

local DelayKetik = 0.05 -- Kecepatan ngetik per huruf (0.05 = natural)

-- ==========================================
-- 1. DATABASE KAMUS (Auto Fetch GitHub)
-- ==========================================
local kamus = {}
local kataTerpakai = {}
local isKamusReady = false

local function loadKamus()
    local url = "https://raw.githubusercontent.com/Bhinneka/indonesian-wordlist/master/kamus.txt"
    local success, response = pcall(function() return game:HttpGet(url) end)

    if success and response then
        for word in string.gmatch(response, "[^\r\n]+") do
            word = string.lower(word)
            local hurufPertama = string.sub(word, 1, 1)
            if not kamus[hurufPertama] then kamus[hurufPertama] = {} end
            table.insert(kamus[hurufPertama], word)
        end
        isKamusReady = true
        return true
    end
    return false
end

-- ==========================================
-- 2. LOGIKA MENCARI & MENGIRIM KATA
-- ==========================================
local function ketikDanKirimKata(kata)
    local remotes = ReplicatedStorage:WaitForChild("Remotes")
    
    -- 1. Mulai
    remotes:WaitForChild("BillboardStart"):FireServer(string.sub(kata, 1, 1))
    task.wait(DelayKetik)
    
    -- 2. Update per huruf
    for i = 2, #kata do
        remotes:WaitForChild("BillboardUpdate"):FireServer(string.sub(kata, 1, i))
        task.wait(DelayKetik)
    end
    
    -- 3. Submit
    remotes:WaitForChild("SubmitWord"):FireServer(kata)
    task.wait(0.1)
    
    -- 4. End
    remotes:WaitForChild("BillboardEnd"):FireServer()
end

local function cariKata(awalan)
    awalan = string.lower(awalan:match("^%s*(.-)%s*$")) -- Bersihkan spasi
    if awalan == "" then return nil end
    
    local hurufPertama = string.sub(awalan, 1, 1)
    local daftarKata = kamus[hurufPertama]
    
    if daftarKata then
        for _, kata in ipairs(daftarKata) do
            if string.sub(kata, 1, #awalan) == awalan and not kataTerpakai[kata] then
                kataTerpakai[kata] = true 
                return kata
            end
        end
    end
    return nil
end

local function eksekusiAutoJawab()
    if not isKamusReady then return "Kamus belum siap!" end
    if not PathTeks_Target then return "Path Teks belum diisi di script!" end
    
    local hurufDiLayar = PathTeks_Target.Text
    if hurufDiLayar == "" then return "Tidak ada huruf terdeteksi" end
    
    local kataPilihan = cariKata(hurufDiLayar)
    if kataPilihan then
        ketikDanKirimKata(kataPilihan)
        return "Berhasil: " .. kataPilihan
    else
        return "Kata awalan '"..hurufDiLayar.."' habis!"
    end
end

