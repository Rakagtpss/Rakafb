-- 🎣 INSTAN FISHING SCRIPT dengan SIMPLE UI
-- Copy-paste langsung ke executor (SynapseX, Krnl, etc.)

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Path Remote (dari query user)
local net = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("sleitnick_net@0.2.0"):WaitForChild("net")

local chargeRod = net:WaitForChild("RF/ce8387781fe14f962f4d74a737b0ebfdae347070f82b867d4639713961a1a2c8")
local lemparBait = net:WaitForChild("RF/3ab64f9b8c1417b91c1b9d9c42a7092e25aba5d66fa2bbe362216c53a0003406")
local dapatIkan = net:WaitForChild("RF/53492427a4a6ec4551121d738f97ec5e2eb77d4678ae9353885fb2a701409d5e")

-- State
local autoFishing = false
local fishingCoroutine = nil

-- Fungsi Instan Fishing Cycle
local function doInstanFishing()
    pcall(function()
        chargeRod:InvokeServer()  -- Charge rod [cite:2]
        task.wait(0.1)
        
        local args = {
            -1.233184814453125,
            0.05894758483513807,
            tick() * 1000  -- Timestamp dinamis biar fresh [web:9]
        }
        lemparBait:InvokeServer(unpack(args))  -- Lempar bait [cite:2]
        task.wait(0.1)
        
        dapatIkan:InvokeServer()  -- Dapat ikan [cite:2]
    end)
end

-- Fungsi Loop Auto
local function startAutoFishing()
    if fishingCoroutine then return end
    fishingCoroutine = coroutine.create(function()
        while autoFishing do
            doInstanFishing()
            task.wait(0.5)  -- Delay minimal anti-detect, sesuaikan [web:6]
        end
    end)
    coroutine.resume(fishingCoroutine)
end

local function stopAutoFishing()
    autoFishing = false
    fishingCoroutine = nil
end

-- Buat Simple UI [web:9]
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "InstanFishingUI"
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 220, 0, 120)
mainFrame.Position = UDim2.new(0, 20, 0, 20)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "🎣 Instan Fishing"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0.9, 0, 0, 35)
toggleBtn.Position = UDim2.new(0.05, 0, 0, 50)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
toggleBtn.Text = "START AUTO"
toggleBtn.TextColor3 = Color3.white
toggleBtn.TextScaled = true
toggleBtn.Font = Enum.Font.Gotham
toggleBtn.Parent = mainFrame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 8)
btnCorner.Parent = toggleBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, 0, 0, 25)
statusLabel.Position = UDim2.new(0, 0, 0, 90)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Status: OFF"
statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = mainFrame

-- Drag UI [web:9]
local dragging = false
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
    end
end)
mainFrame.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        mainFrame.Position = UDim2.new(mainFrame.Position.X.Scale, mainFrame.Position.X.Offset + input.Delta.X, mainFrame.Position.Y.Scale, mainFrame.Position.Y.Offset + input.Delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Toggle Logic
toggleBtn.MouseButton1Click:Connect(function()
    autoFishing = not autoFishing
    
    if autoFishing then
        toggleBtn.Text = "STOP AUTO"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        statusLabel.Text = "Status: ON"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
        startAutoFishing()
    else
        toggleBtn.Text = "START AUTO"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        statusLabel.Text = "Status: OFF"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        stopAutoFishing()
    end
end)

-- Animasi Hover
local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
toggleBtn.MouseEnter:Connect(function()
    TweenService:Create(toggleBtn, tweenInfo, {Size = UDim2.new(0.92, 0, 0, 37)}):Play()
end)
toggleBtn.MouseLeave:Connect(function()
    TweenService:Create(toggleBtn, tweenInfo, {Size = UDim2.new(0.9, 0, 0, 35)}):Play()
end)

print("🎣 Instan Fishing UI Loaded! Drag frame untuk pindah posisi. [web:9][cite:4]")
